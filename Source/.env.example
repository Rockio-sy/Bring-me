
# Copy this file to `.env` for Docker Compose or export the variables locally.
# Replace every placeholder value before running the app.

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bringme
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DB=bringme

# Flyway
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# Uploads
FILE_UPLOAD_DIR=./photos
FILE_UPLOAD_TEMP_DIR=./photos/tmp

# JWT
JWT_SECRET=change-this-secret-before-sharing

# Email service
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
